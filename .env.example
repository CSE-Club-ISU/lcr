# SpacetimeDB connection (used by executor to call reducers)
SPACETIMEDB_HOST=http://localhost:3000
SPACETIMEDB_DB_NAME=lcr

# Executor service
EXECUTOR_PORT=8000
RATE_LIMIT_COOLDOWN_MS=5000   # min ms between submissions per game_id

# Docker image tags for code execution sandboxes
DOCKER_IMAGE_PYTHON=python:3.12-slim
DOCKER_IMAGE_JAVA=openjdk:21-slim
DOCKER_IMAGE_CPP=gcc:13

# Per-language resource limits
# C++ needs >=512m for nlohmann/json compilation; Java's harness JSON parser
# similarly needs javac headroom. CPU=1.0 keeps compile times reasonable.
DOCKER_PYTHON_MEMORY=256m
DOCKER_JAVA_MEMORY=512m
DOCKER_CPP_MEMORY=512m

DOCKER_PYTHON_TIME_LIMIT_MS=8000
DOCKER_JAVA_TIME_LIMIT_MS=12000
DOCKER_CPP_TIME_LIMIT_MS=10000

DOCKER_CPU_LIMIT=1.0

# GitHub OAuth — create an app at https://github.com/settings/developers
# Authorization callback URL: http://localhost:4000/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Auth server
AUTH_SERVER_URL=http://localhost:4000
# Where GitHub redirects after OAuth (must match your GitHub app settings if using a proxy)
# The auth server /callback redirects to this URL with ?id_token=...
AUTH_REDIRECT_URI=http://localhost:5173/auth/callback

# Optional: provide PEM-encoded RSA keys instead of auto-generating
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=
